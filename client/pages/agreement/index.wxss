.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 0 32rpx 40rpx;
}

.header {
  padding: 40rpx 0 32rpx;
  border-bottom: 1rpx solid #E8E8E8;
  background: #F5F7FA;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1A1A2E;
  display: block;
  margin-bottom: 12rpx;
}

.update-time {
  font-size: 24rpx;
  color: #999;
}

.content {
  padding-top: 32rpx;
}

.section {
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A2E;
  display: block;
  margin-bottom: 20rpx;
}

.section-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
  margin-bottom: 12rpx;
}
