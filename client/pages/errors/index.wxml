<view class="container">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab {{tab === 'pending' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="pending">待订正</view>
    <view class="tab {{tab === 'reviewed' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="reviewed">已订正</view>
  </view>

  <view wx:if="{{list.length === 0 && !loading}}" class="empty">
    <text class="empty-icon">🎉</text>
    <text class="empty-text">{{tab === 'pending' ? '没有待订正的错题' : '还没有订正记录'}}</text>
  </view>

  <view wx:for="{{list}}" wx:key="id" class="card error-item">
    <view class="error-left">
      <text class="error-expression">{{item.expression}}</text>
      <view class="error-answers">
        <text class="text-red">你答：{{item.user_answer}}</text>
        <text class="text-green">正确：{{item.correct_answer}}</text>
      </view>
      <text class="error-time">{{item.create_time}}</text>
    </view>
    <view wx:if="{{tab === 'pending'}}" class="review-btn" bindtap="startReview" data-index="{{index}}">订正</view>
    <view wx:else class="reviewed-badge">✅</view>
  </view>

  <view wx:if="{{loading}}" class="load-more">加载中...</view>
  <view wx:if="{{!loading && hasMore}}" class="load-more" bindtap="loadMore">加载更多</view>
</view>
