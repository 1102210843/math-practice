.container {
  padding: 30rpx;
  background: #F0F4FA;
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  color: #999;
}

.tab-active {
  color: #3478F6;
  font-weight: bold;
  background: #EBF2FF;
}

.error-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
}

.error-expression {
  font-size: 36rpx;
  font-weight: bold;
  font-family: 'Menlo', monospace;
  display: block;
  margin-bottom: 8rpx;
}

.error-answers {
  display: flex;
  gap: 24rpx;
  font-size: 26rpx;
  margin-bottom: 6rpx;
}

.error-time {
  font-size: 22rpx;
  color: #ccc;
}

.review-btn {
  background: #3478F6;
  color: #fff;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.reviewed-badge {
  font-size: 32rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #3478F6;
  font-size: 28rpx;
}

.review-area {
  margin-top: 20rpx;
}

.review-card {
  text-align: center;
  padding: 50rpx 30rpx;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.review-expression {
  font-size: 64rpx;
  font-weight: bold;
  font-family: 'Menlo', monospace;
}

.review-input-area {
  margin-top: 20rpx;
}

.review-input {
  font-size: 56rpx;
  font-weight: bold;
  color: #3478F6;
  font-family: 'Menlo', monospace;
}

.review-feedback {
  margin-top: 24rpx;
}

.feedback-big {
  font-size: 36rpx;
  font-weight: bold;
}

.correct-hint {
  display: block;
  font-size: 30rpx;
  color: #FFA726;
  margin-top: 10rpx;
}

.numpad {
  padding: 20rpx 0;
}

.numpad-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.numpad-key {
  width: 180rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: bold;
  background: #fff;
  border-radius: 16rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.numpad-key:active { background: #E8E8E8; }
.key-del { color: #999; font-size: 38rpx; }
.key-confirm { background: #3478F6; color: #fff; font-size: 32rpx; }
.key-confirm:active { background: #2B6AE0; }
