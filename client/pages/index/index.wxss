.page-bg {
  min-height: 100vh;
  background: #F0F4FA;
}

/* ===== 蓝色头部背景（弧形底部） ===== */
.header-bg {
  background: linear-gradient(180deg, #2E6FF2 0%, #4E96FF 100%);
  padding-bottom: 180rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.custom-nav {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 34rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* ===== 用户卡片（骑跨蓝灰交界） ===== */
.user-card {
  display: flex;
  align-items: center;
  margin: -140rpx 28rpx 0;
  padding: 36rpx 32rpx;
  background: linear-gradient(135deg, #3E85FA 0%, #5EA8FF 100%);
  border-radius: 28rpx;
  box-shadow: inset 0 0 40rpx rgba(255, 255, 255, 0.6), 0 8rpx 24rpx rgba(46, 111, 242, 0.3);
  position: relative;
  z-index: 10;
}

.user-card-left {
  flex: 1;
}

.greeting-line1 {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
  line-height: 1.4;
}

.greeting-line2 {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1.3;
  margin-bottom: 16rpx;
}

.user-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.star-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
}

.level-badge {
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.3);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.mascot-img {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  margin-right: -8rpx;
  margin-top: -20rpx;
  margin-bottom: -20rpx;
}

/* ===== 内容区域 ===== */
.content-area {
  padding: 28rpx 28rpx 40rpx;
}

/* ===== Section 标题 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-header-calendar {
  margin-top: 12rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-bar {
  width: 8rpx;
  height: 34rpx;
  background: #3478F6;
  border-radius: 4rpx;
}

.section-title-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A2E;
}

/* ===== 任务卡片 ===== */
.task-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.task-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
  overflow: hidden;
}

.task-icon-img {
  width: 96rpx;
  height: 96rpx;
}

.task-icon-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.task-info {
  flex: 1;
}

.task-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 8rpx;
}

.task-desc {
  font-size: 24rpx;
  color: #A0A0B0;
  display: block;
}

.start-btn {
  background: #3478F6;
  color: #fff;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.start-btn:active {
  opacity: 0.85;
}

.done-badge {
  color: #66BB6A;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* ===== 日历卡片 ===== */
.calendar-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.cal-header {
  display: flex;
  margin-bottom: 8rpx;
}

.cal-week-day {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #888;
  padding-bottom: 16rpx;
}

.cal-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-day-wrap {
  width: calc(100% / 7);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
}

.cal-day {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
  border-radius: 50%;
}

.cal-today {
  background: #3478F6;
  color: #fff;
  font-weight: bold;
}

.cal-done {
  background: #E3F0FF;
  color: #3478F6;
  font-weight: 500;
}

.cal-today.cal-done {
  background: #3478F6;
  color: #fff;
}
