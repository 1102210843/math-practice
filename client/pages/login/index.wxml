<view class="login-page">
  <view style="height: {{statusBarHeight}}px;"></view>

  <view class="hero-area">
    <image class="mascot" src="{{logoUrl}}" mode="aspectFit"></image>
    <text class="app-name">口算小达人</text>
    <text class="app-desc">每天练一练，数学顶呱呱</text>
  </view>

  <view class="bottom-area">
    <button class="btn-phone" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <view class="btn-inner">
        <image class="wechat-icon" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='white'%3E%3Cpath d='M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05a6.127 6.127 0 01-.253-1.736c0-3.54 3.28-6.41 7.326-6.41.18 0 .354.014.53.025C16.534 4.39 13.064 2.188 8.691 2.188zm-2.87 4.11a1.12 1.12 0 110 2.24 1.12 1.12 0 010-2.24zm5.74 0a1.12 1.12 0 110 2.24 1.12 1.12 0 010-2.24z'/%3E%3Cpath d='M23.997 14.637c0-3.2-3.28-5.793-7.326-5.793-4.046 0-7.326 2.593-7.326 5.793s3.28 5.793 7.326 5.793c.94 0 1.837-.146 2.665-.403a.72.72 0 01.598.08l1.586.93a.274.274 0 00.14.045c.133 0 .242-.11.242-.245 0-.06-.024-.118-.04-.177l-.326-1.232a.494.494 0 01.178-.555c1.53-1.127 2.503-2.77 2.503-4.241zm-9.776-1.267a.935.935 0 110-1.87.935.935 0 010 1.87zm4.9 0a.935.935 0 110-1.87.935.935 0 010 1.87z'/%3E%3C/svg%3E" mode="aspectFit" />
        <text class="btn-text">手机号快捷登录</text>
      </view>
    </button>
    <view wx:if="{{loading}}" class="loading-text">登录中...</view>
    <view class="hint-text">
      <text>登录即表示同意</text>
      <text class="link" bindtap="goAgreement">用户协议</text>
      <text>和</text>
      <text class="link" bindtap="goPrivacy">隐私政策</text>
    </view>
  </view>
</view>