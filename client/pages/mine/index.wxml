<view class="page-bg">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="card-bg"></view>
    <view class="card-content">
      <view class="avatar-col">
        <view class="avatar-wrap">
          <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image class="avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
          </button>
          <view class="avatar-badge">
            <text class="badge-text">换头像</text>
          </view>
        </view>
      </view>
      <view class="user-info">
        <view class="user-meta">
          <view class="nickname-row">
            <input class="nickname-input" type="nickname" value="{{nickname}}" bindblur="onNicknameBlur" placeholder="点击设置昵称" />
          </view>
          <view class="level-pill">
            <text class="level-pill-text">🏅 Lv.{{level}} {{levelName}}</text>
          </view>
        </view>
        <view class="stats-row stats-row-two">
          <view class="stat-item stat-item-compact">
            <text class="stat-num">{{totalStars}}</text>
            <text class="stat-label">星星</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item stat-item-wide">
            <text class="stat-num">{{streakDays}}<text class="stat-unit">天</text></text>
            <text class="stat-label">连续打卡</text>
            <text class="stat-sub">最长 {{maxStreakDays}} 天</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="section-row">
    <view class="section-bar"></view>
    <text class="section-title">设置</text>
  </view>

  <view class="settings-card">
    <view class="menu-item" bindtap="showGradePicker">
      <view class="menu-left">
        <view class="icon-circle icon-bg-blue"><text class="icon-inner">📚</text></view>
        <text class="menu-text">当前年级</text>
      </view>
      <text class="menu-value">{{gradeText}} ▸</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item">
      <view class="menu-left">
        <view class="icon-circle icon-bg-purple"><text class="icon-inner">🔊</text></view>
        <text class="menu-text">音效</text>
      </view>
      <switch checked="{{soundEnabled}}" bindchange="toggleSound" color="#3478F6" />
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="showCountPicker">
      <view class="menu-left">
        <view class="icon-circle icon-bg-green"><text class="icon-inner">📝</text></view>
        <text class="menu-text">口算题数</text>
      </view>
      <text class="menu-value">{{questionCount}} 题 ▸</text>
    </view>
  </view>

  <!-- 学习记录 -->
  <view class="section-row">
    <view class="section-bar"></view>
    <text class="section-title">学习记录</text>
  </view>

  <view class="settings-card">
    <view class="menu-item" bindtap="goHistory">
      <view class="menu-left">
        <view class="icon-circle icon-bg-blue"><text class="icon-inner">📋</text></view>
        <text class="menu-text">练习记录</text>
      </view>
      <text class="menu-arrow">▸</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goErrors">
      <view class="menu-left">
        <view class="icon-circle icon-bg-orange"><text class="icon-inner">📕</text></view>
        <text class="menu-text">口算错题本</text>
      </view>
      <text class="menu-arrow">▸</text>
    </view>
  </view>

  <!-- 徽章展示 -->
  <view wx:if="{{badges.length > 0}}">
    <view class="section-row">
      <view class="section-bar"></view>
      <text class="section-title">我的徽章</text>
    </view>
    <view class="settings-card badges-card">
      <view class="badge-grid">
        <view wx:for="{{badges}}" wx:key="id" class="badge-item">
          <text class="badge-icon">{{item.icon}}</text>
          <text class="badge-name">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 年级选择弹窗 -->
  <view class="modal-mask" wx:if="{{showGrade}}" bindtap="hideGradePicker">
    <view class="modal-body" catchtap>
      <text class="modal-title">选择你的年级</text>
      <view class="grade-grid">
        <view
          wx:for="{{grades}}"
          wx:key="value"
          class="grade-item {{grade === item.value ? 'grade-active' : ''}}"
          bindtap="pickGrade"
          data-grade="{{item.value}}"
        >
          <text class="grade-icon">{{item.icon}}</text>
          <text class="grade-label">{{item.label}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
