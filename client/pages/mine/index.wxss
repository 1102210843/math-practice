page {
  background: #2E6FF2;
}

.page-bg {
  min-height: 100vh;
  background: #F0F4FA;
  padding: 24rpx 28rpx 40rpx;
  border-radius: 32rpx 32rpx 0 0;
}

/* ===== 用户卡片 ===== */
.user-card {
  position: relative;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(46, 111, 242, 0.3);
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #3E85FA 0%, #5EA8FF 50%, #7BC4FF 100%);
}

.card-bg::after {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.card-content {
  position: relative;
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 32rpx;
  gap: 24rpx;
}

/* 头像：固定正方形 + 外层包裹，避免 button 默认拉宽成椭圆 */
.avatar-col {
  flex: 0 0 auto;
  width: 144rpx;
  box-sizing: border-box;
  padding-top: 4rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  flex-shrink: 0;
}

.avatar-btn {
  width: 144rpx !important;
  height: 144rpx !important;
  min-width: 144rpx !important;
  max-width: 144rpx !important;
  min-height: 144rpx !important;
  max-height: 144rpx !important;
  padding: 0 !important;
  margin: 0;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  overflow: hidden;
  line-height: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.55);
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.avatar-badge {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  background: rgba(0, 0, 0, 0.55);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  max-width: 140rpx;
}

.badge-text {
  font-size: 18rpx;
  color: #fff;
  white-space: nowrap;
}

.user-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  justify-content: center;
  gap: 20rpx;
}

.user-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.nickname-row {
  margin-bottom: 0;
}

.nickname-input {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  background: transparent;
  padding: 0;
  min-height: 48rpx;
  line-height: 1.35;
  width: 100%;
  box-sizing: border-box;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.65);
}

.level-pill {
  align-self: flex-start;
  margin-bottom: 0;
  padding: 6rpx 18rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  max-width: 100%;
  box-sizing: border-box;
}

.level-pill-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stats-row {
  display: flex;
  align-items: stretch;
  background: rgba(255, 255, 255, 0.16);
  border-radius: 16rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.stats-row-two .stat-item-compact {
  flex: 0 0 108rpx;
  align-items: flex-start;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 4rpx;
  min-width: 0;
}

.stat-item-wide {
  flex: 1;
  align-items: flex-start;
  padding-left: 8rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.15;
}

.stat-unit {
  font-size: 24rpx;
  font-weight: 600;
  margin-left: 2rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.2;
}

.stat-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.68);
  margin-top: 2rpx;
  line-height: 1.25;
}

.stat-divider {
  width: 1rpx;
  align-self: stretch;
  min-height: 64rpx;
  margin: 0 4rpx;
  background: rgba(255, 255, 255, 0.28);
  flex-shrink: 0;
}

/* ===== Section 标题 ===== */
.section-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 20rpx 0 12rpx;
  padding: 0 4rpx;
}

.section-bar {
  width: 8rpx;
  height: 32rpx;
  background: #3478F6;
  border-radius: 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1A2E;
}

/* ===== 设置卡片（合并） ===== */
.settings-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-inner {
  font-size: 32rpx;
}

.icon-bg-blue {
  background: #EBF2FF;
}

.icon-bg-purple {
  background: #F0ECFF;
}

.icon-bg-green {
  background: #E8F8E8;
}

.icon-bg-orange {
  background: #FFF0E6;
}

.menu-text {
  font-size: 30rpx;
  color: #1A1A2E;
}

.menu-value {
  color: #999;
  font-size: 28rpx;
}

.menu-arrow {
  color: #C0C8D4;
  font-size: 28rpx;
}

.menu-divider {
  height: 1rpx;
  background: #F0F2F5;
  margin: 0 30rpx;
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-body {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 30rpx 60rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
}

.grade-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.grade-item {
  width: 280rpx;
  padding: 30rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.grade-active {
  border-color: #3478F6;
  background: #EBF2FF;
}

.grade-icon {
  font-size: 40rpx;
}

.grade-label {
  font-size: 28rpx;
}

/* ===== 徽章 ===== */
.badges-card {
  padding: 24rpx;
}

.badge-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.badge-item {
  width: calc(33.33% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.badge-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.badge-name {
  font-size: 22rpx;
  color: #666;
}
