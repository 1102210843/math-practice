page {
  background: #2E6FF2;
}

.page-bg {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F0F4FA;
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -2rpx;
}

/* ===== 顶部信息栏 ===== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-label {
  display: flex;
  align-items: baseline;
}

.progress-num {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A2E;
}

.progress-unit {
  font-size: 28rpx;
  color: #999;
  margin-left: 4rpx;
}

.timer {
  font-size: 28rpx;
  color: #999;
}

/* ===== 进度条 ===== */
.progress-wrapper {
  height: 14rpx;
  background: #E0E8F0;
  border-radius: 7rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3478F6, #5EA8FF);
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

/* ===== 算式区域 ===== */
.expression-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  flex: 1;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: background 0.3s;
}

.expression-area.feedback-correct {
  background: rgba(102, 187, 106, 0.08);
}

.expression-area.feedback-wrong {
  background: rgba(239, 83, 80, 0.08);
}

.expression-line {
  display: flex;
  align-items: baseline;
}

.expression-text {
  font-size: 80rpx;
  font-weight: bold;
  color: #1A1A2E;
}

.expression-q {
  font-size: 80rpx;
  font-weight: bold;
  color: #3478F6;
}

.expression-answer {
  font-size: 80rpx;
  font-weight: bold;
  color: #3478F6;
}

.input-indicator {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-cursor {
  width: 60rpx;
  height: 6rpx;
  background: #CCC;
  border-radius: 3rpx;
}

.feedback {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feedback-icon {
  font-size: 48rpx;
}

.feedback-wrong {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.correct-hint {
  font-size: 32rpx;
  color: #FFA726;
  margin-top: 10rpx;
  font-weight: bold;
}

/* ===== 数字键盘 ===== */
.numpad {
  padding: 10rpx 0 40rpx;
  flex-shrink: 0;
}

.numpad-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.numpad-key {
  flex: 1;
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  background: #fff;
  border-radius: 20rpx;
  color: #1A1A2E;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.numpad-key:active {
  background: #E8ECF2;
  transform: scale(0.97);
}

.key-del {
  color: #999;
  font-size: 44rpx;
}

.key-confirm {
  background: #3478F6;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
}

.key-confirm:active {
  background: #2B6AE0;
}
