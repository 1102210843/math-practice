.container {
  padding: 30rpx;
  background: #F0F4FA;
  min-height: 100vh;
}

.result-header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.stars {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.star {
  font-size: 40rpx;
}

.stars-text {
  font-size: 32rpx;
  color: #FFB74D;
  font-weight: bold;
  margin-left: 8rpx;
}

.stats-card {
  text-align: center;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
}

.error-card {
  padding: 24rpx 30rpx;
}

.error-expression {
  font-size: 36rpx;
  font-weight: bold;
  font-family: 'Menlo', monospace;
  display: block;
  margin-bottom: 12rpx;
}

.error-detail {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
}

.perfect-msg {
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #66BB6A;
  padding: 40rpx 0;
}

.btn-primary {
  margin-top: 40rpx;
  background: #3478F6;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}
