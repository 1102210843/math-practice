page {
  background: #2E6FF2;
}

.page-bg {
  min-height: 100vh;
  background: #F0F4FA;
  padding: 24rpx 28rpx 40rpx;
  border-radius: 32rpx 32rpx 0 0;
}

/* ===== Tab 切换 ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  font-size: 30rpx;
  color: #999;
  transition: all 0.2s;
}

.tab-active {
  color: #3478F6;
  font-weight: bold;
  background: #EBF2FF;
}

/* ===== Section 标题 ===== */
.section-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 12rpx 0 8rpx;
  padding: 0 4rpx;
}

.section-bar {
  width: 8rpx;
  height: 32rpx;
  background: #3478F6;
  border-radius: 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A1A2E;
}

/* ===== 报告卡片 ===== */
.report-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A2E;
  display: block;
  margin-bottom: 20rpx;
}

/* ===== 图表区域 ===== */
.chart-area {
  display: flex;
  height: 320rpx;
  margin-bottom: 24rpx;
}

.chart-y-axis {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: 80rpx;
  padding-right: 10rpx;
}

.chart-y-axis text {
  font-size: 20rpx;
  color: #C0C8D4;
  text-align: right;
}

.chart-body {
  flex: 1;
  border-left: 1rpx solid #E8EDF3;
  border-bottom: 1rpx solid #E8EDF3;
  position: relative;
  display: flex;
  flex-direction: column;
}

.chart-bars {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding: 0 10rpx;
}

.chart-bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.chart-bar {
  width: 40rpx;
  background: linear-gradient(to top, #3478F6, #5EA8FF);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  position: relative;
}

.bar-value {
  font-size: 18rpx;
  color: #3478F6;
  position: absolute;
  top: -30rpx;
  white-space: nowrap;
}

.bar-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 暂无数据占位 */
.chart-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0;
}

.empty-img {
  width: 320rpx;
  height: 200rpx;
  margin-bottom: -20rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #B0BEC5;
}

.chart-x-labels {
  display: flex;
  justify-content: space-around;
  padding: 8rpx 10rpx 0;
}

.chart-x-labels text {
  font-size: 22rpx;
  color: #999;
  width: 60rpx;
  text-align: center;
}

/* ===== 统计行（带分隔线） ===== */
.stats-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0 8rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E8EDF3;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1A1A2E;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.text-blue {
  color: #3478F6;
}

.text-green {
  color: #34C759;
}

.text-orange {
  color: #FF9500;
}

/* ===== 带插图的统计（读题、打卡） ===== */
.stats-with-illust {
  display: flex;
  align-items: center;
}

.stats-col {
  flex: 1;
  display: flex;
  gap: 20rpx;
}

.stat-item-v {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rpx 0;
}

.illust-area {
  width: 280rpx;
  height: 130rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.illust-reading {
}

.illust-checkin {
}

.illust-img {
  width: 240rpx;
  height: 130rpx;
}

/* ===== 薄弱项分析 ===== */
.weak-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F2F5;
}

.weak-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFA726;
  display: block;
  margin-bottom: 20rpx;
}

.weak-bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.weak-label {
  font-size: 26rpx;
  width: 80rpx;
  color: #666;
}

.weak-bar {
  flex: 1;
  height: 28rpx;
  background: #F0F2F5;
  border-radius: 14rpx;
  overflow: hidden;
}

.weak-bar-fill {
  height: 100%;
  border-radius: 14rpx;
  transition: width 0.5s ease;
}

.weak-bar-high {
  background: #EF5350;
}

.weak-bar-mid {
  background: #FFA726;
}

.weak-bar-low {
  background: #66BB6A;
}

.weak-count {
  font-size: 22rpx;
  color: #999;
  width: 140rpx;
  text-align: right;
}

.weak-tip {
  margin-top: 16rpx;
  padding: 14rpx 20rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #F57C00;
}

.weak-hint {
  text-align: center;
  padding: 16rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  margin-top: 16rpx;
  font-size: 26rpx;
}
